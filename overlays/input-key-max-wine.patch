 #include <linux/input-event-codes.h>

+/* Increase kernel input limits */
+#ifdef KEY_MAX
+#undef KEY_MAX
+#define KEY_MAX 0x4ff
+#endif
+
+#ifdef KEY_CNT
+#undef KEY_CNT
+#define KEY_CNT (KEY_MAX + 1)
+#endif
+
+/* Increase Wine internal key tracking */
+#define WINE_MAX_KEYS KEY_CNT

